{
  "name": "evermemory",
  "version": "0.0.1",
  "private": false,
  "description": "EverMemory deterministic memory plugin for OpenClaw with intent and reflection baseline.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": "22.x"
  },
  "files": [
    "dist",
    "index.js",
    "index.ts",
    "openclaw.plugin.json",
    "plugin.json",
    "README.md",
    "docs/evermemory-installation-guide.md"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "clean": "rm -rf dist dist-test",
    "build": "node ./scripts/build-with-fingerprint.mjs",
    "build:test": "rm -rf dist-test .tsbuildinfo-test && tsc -p tsconfig.test.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "doctor": "node ./scripts/doctor.mjs",
    "repo:guard": "node ./scripts/git-branch-guard.mjs",
    "repo:guard:allow-main": "node ./scripts/git-branch-guard.mjs --allow-main",
    "evidence:latest": "node ./scripts/evidence-latest.mjs",
    "openclaw:harden": "node ./scripts/openclaw-host-hardening.mjs",
    "openclaw:cleanup:test-data": "node ./scripts/openclaw-purge-test-data.mjs",
    "openclaw:cleanup:test-data:dry": "node ./scripts/openclaw-purge-test-data.mjs --dry-run",
    "openclaw:security:recover": "node ./scripts/openclaw-security-recover.mjs --with-release",
    "openclaw:security:drill": "node ./scripts/openclaw-security-recover.mjs --force-harden --with-release",
    "teams:status": "node ./scripts/agent-teams-supervisor.mjs --mode=status",
    "teams:dev": "node ./scripts/agent-teams-supervisor.mjs --mode=dev",
    "teams:release": "node ./scripts/agent-teams-supervisor.mjs --mode=release",
    "quality:gate": "node ./scripts/quality-gate.mjs",
    "quality:gate:openclaw": "node ./scripts/quality-gate.mjs --with-openclaw --with-continuity --with-security",
    "quality:gate:feishu-qgent": "node ./scripts/quality-gate.mjs --with-openclaw --with-continuity --with-feishu-qgent --with-security",
    "quality:gate:full": "node ./scripts/quality-gate.mjs --with-openclaw --with-continuity --with-security --with-soak",
    "test:openclaw:feishu-qgent": "node ./scripts/openclaw-feishu-qgent-e2e.mjs",
    "test:openclaw:continuity": "node ./scripts/openclaw-continuity-e2e.mjs",
    "test:openclaw:continuity:matrix": "node ./scripts/openclaw-continuity-matrix.mjs --runs=3",
    "test:openclaw:continuity:matrix:short": "node ./scripts/openclaw-continuity-matrix.mjs --runs=2",
    "test:openclaw:smoke": "node ./scripts/openclaw-smoke.mjs",
    "test:openclaw:security": "node ./scripts/openclaw-security-gate.mjs",
    "test:openclaw:soak": "node ./scripts/openclaw-real-soak.mjs --iterations=6 --security-every=2",
    "test:openclaw:soak:feishu": "node ./scripts/openclaw-real-soak.mjs --iterations=4 --security-every=2 --with-feishu",
    "test:openclaw:soak:release": "node ./scripts/openclaw-real-soak.mjs --iterations=2 --security-every=1 --without-continuity",
    "test:recall:benchmark": "node ./scripts/build-if-needed.mjs && node ./scripts/recall-benchmark.mjs",
    "test:recall:benchmark:baseline": "node ./scripts/build-if-needed.mjs && node ./scripts/recall-benchmark.mjs --update-baseline",
    "release:evaluate": "node ./scripts/release-evaluate.mjs",
    "release:pack": "node ./scripts/release-pack.mjs",
    "release:0.0.1:evaluate": "node ./scripts/release-evaluate.mjs --version 0.0.1",
    "release:0.0.1:pack": "node ./scripts/release-pack.mjs --version 0.0.1",
    "test:unit": "npm run build:test && node --test $(find dist-test/test -name '*.test.js' -print)",
    "test": "npm run test:unit",
    "validate": "npm run doctor && npm run check && npm run test:unit",
    "kpi:track": "node ./scripts/kpi-tracker.mjs",
    "kpi:update": "node ./scripts/kpi-tracker.mjs --update-baseline",
    "growth:report": "node ./scripts/growth-report.mjs",
    "stability:check": "node ./scripts/stability-check.mjs",
    "stability:check:full": "node ./scripts/stability-check.mjs --with-soak"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.9.2"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^12.2.0"
  }
}
