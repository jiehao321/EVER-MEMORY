{
  "name": "evermemory",
  "version": "0.1.0",
  "private": true,
  "description": "EverMemory deterministic memory plugin for OpenClaw with intent and reflection baseline.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": "22.x"
  },
  "files": [
    "dist",
    "index.ts",
    "openclaw.plugin.json",
    "plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "clean": "rm -rf dist dist-test",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "build:test": "rm -rf dist-test && tsc -p tsconfig.test.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "doctor": "node ./scripts/doctor.mjs",
    "quality:gate": "node ./scripts/quality-gate.mjs",
    "quality:gate:openclaw": "node ./scripts/quality-gate.mjs --with-openclaw --with-security",
    "test:openclaw:smoke": "node ./scripts/openclaw-smoke.mjs",
    "test:openclaw:security": "node ./scripts/openclaw-security-gate.mjs",
    "test:unit": "npm run build:test && node --test dist-test/test/*.test.js",
    "test": "npm run test:unit",
    "validate": "npm run doctor && npm run check && npm run test:unit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^12.2.0"
  }
}
